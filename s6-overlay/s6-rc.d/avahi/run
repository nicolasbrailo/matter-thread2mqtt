#!/usr/bin/env bash
# Longrun: avahi-daemon, the mDNS publisher used for Matter/Thread discovery.
# -f keeps it in the foreground (no --daemonize) so s6 supervises and restarts it.
# --no-rlimits: avahi can't raise rlimits in a container; don't let that abort it.
set -euo pipefail

exec 2>&1                         # fold stderr into stdout so avahi-log captures it
exec avahi-daemon -f --no-rlimits
